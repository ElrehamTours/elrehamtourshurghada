  >
    <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M20.52 3.48A11.88 11.88 0 0 0 12.06 0C5.46 0 .08 5.37.08 11.97c0 2.11.55 4.17 1.6 5.99L0 24l6.2-1.63a11.96 11.96 0 0 0 5.86 1.49h.01c6.6 0 11.97-5.37 11.98-11.97 0-3.2-1.25-6.2-3.53-8.41zM12.07 21.84h-.01a9.93 9.93 0 0 1-5.06-1.38l-.36-.21-3.68.97.98-3.59-.23-.37a9.94 9.94 0 0 1-1.52-5.29c0-5.49 4.47-9.96 9.97-9.96a9.9 9.9 0 0 1 7.04 2.92 9.9 9.9 0 0 1 2.92 7.04c0 5.49-4.47 9.96-9.96 9.96z"/>
    </svg>
    <span>تواصل واتساب للحجز الفوري</span>
  </a>

  <script>
    function sendMain() {
      const f = document.getElementById('w-from').value;
      const t_ = document.getElementById('w-to').value;
      const d = document.getElementById('w-date').value;
      const p = document.getElementById('w-phone').value;
      const n = document.getElementById('w-name').value;

      if (!f || !t_ || !d || !p || !n) {
        alert('أبشر، يرجى ملء كافة الخانات لتزويدك بأدق سعر للرحلة.');
        return;
      }

      // تتبع النقرة وإرسال الإحالة لجوجل إدز
      trackLead('landing_booking_submit', 'main_landing_form');

      fetch('https://script.google.com/macros/s/AKfycbxGgySg1t6yVUE_d6Ib2AjJU__Rm18KC44SlPkCOIrW9fvSGsKTJBapuYQ7ju2R43fQfw/exec', {
        method: 'POST',
        body: new URLSearchParams({
          tripType: 'LandingKSA',
          from: f,
          to: t_,
          date: d,
          phone: p,
          name: n
        }),
        mode: 'no-cors'
      });

      alert('تم استلام طلبك بنجاح يافندم، سيقوم موظف الحجوزات بالتواصل معك عبر الواتساب فوراً.');
    }

    window.onload = () => {
      // ضبط أقل تاريخ ممكن ليكون اليوم لمنع حجوزات التواريخ القديمة
      const today = new Date().toISOString().split('T')[0];
      const dateInput = document.getElementById('w-date'); 
      if (dateInput) dateInput.setAttribute('min', today);
    };
  </script>
</body>
