  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>أفضل عروض الطيران الحصرية | الريهام تورز</title>

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-687NXW78R5"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    gtag('js', new Date());

    /* GA4 Property */
    gtag('config', 'G-687NXW78R5');

    /* Google Ads Account Tag */
    gtag('config', 'AW-17491889350');

    // دالة التتبع الاحترافية لربط نقرات الواتساب والفورم بجوجل إدز مباشرة
    function trackLead(eventName, eventLabel) {
      if (typeof gtag === 'function') {
        // إرسال الحدث لـ GA4
        gtag('event', eventName, {
          event_category: 'lead',
          event_label: eventLabel
        });
        
        // إرسال التحويل الأساسي لحملة جوجل Ads (Contact Goal)
        gtag('event', 'conversion', {
          'send_to': 'AW-17491889350',
          'value': 1.0,
          'currency': 'EGP'
        });
      }
    }
  </script>

  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root { --brand: #F26522; --navy: #06152c; }
    body { font-family: "Cairo", "Tajawal", sans-serif; background: #040d1a; color: white; overflow-x: hidden; }

    .video-bg-container { 
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
      z-index: -2; overflow: hidden; 
    }
    .video-bg-container video { width: 100%; height: 100%; object-fit: cover; }
    .video-overlay { 
      position: fixed; inset: 0; 
      background: linear-gradient(to bottom, rgba(6, 21, 44, 0.6) 0%, rgba(6, 21, 44, 0.4) 50%, rgba(6, 21, 44, 0.9) 100%); 
      z-index: -1; 
    }

    .hero-simple { 
      background: rgba(6, 21, 44, 0.6); backdrop-filter: blur(12px); 
      border-bottom: 1px solid rgba(255,255,255,0.08); 
      padding: 15px 0; text-align: center; color: white; position: sticky; top: 0; z-index: 100;
    }

    .widget-box { 
      background: rgba(10, 29, 56, 0.75); backdrop-filter: blur(20px); 
      border-radius: 2rem; border: 1px solid rgba(255,255,255,0.1); 
      border-top: 4px solid var(--brand); box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6); 
    }
    .input-group { 
      background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255, 255, 255, 0.15); 
      border-radius: 1rem; padding: 0.7rem 1rem; transition: 0.3s; display: flex; align-items: center; gap: 10px; 
    }
    .input-group:focus-within { border-color: var(--brand); background: rgba(0, 0, 0, 0.6); }
    .input-group input { background: transparent; width: 100%; outline: none; color: white; font-weight: 700; font-size: 0.9rem; }
    .input-group select { background: transparent; width: 100%; outline: none; color: white; font-weight: 700; font-size: 0.9rem; border: 0; cursor: pointer; }
    .input-group select option { background: #06152c; color: white; font-weight: 700; }
    .input-group svg { color: var(--brand); flex-shrink: 0; opacity: 0.9; width: 18px; }
    input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); cursor: pointer; }

    .service-card { 
      background: rgba(255,255,255,0.98); border-radius: 1.5rem; padding: 2rem; 
      text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.3); 
      transition: 0.4s; border: 1px solid transparent; color: var(--navy);
    }
    .service-card:hover { transform: translateY(-5px); border-color: var(--brand); }

    footer { background: rgba(4, 13, 26, 0.98); backdrop-filter: blur(10px); color: white; padding: 40px 20px 30px; border-top: 1px solid rgba(255,255,255,0.05); }

    .floating-whatsapp {
      position: fixed; bottom: 24px; left: 24px; z-index: 9999;
      display: inline-flex; align-items: center; gap: 10px;
      background: #25D366; color: #fff; padding: 14px 22px;
      border-radius: 999px; font-weight: 900; font-size: 15px;
      box-shadow: 0 14px 35px rgba(37,211,102,0.4);
      border: 1px solid rgba(255,255,255,0.25);
      transition: all 0.25s ease; text-decoration: none;
    }
    .floating-whatsapp:hover {
      transform: translateY(-4px) scale(1.02);
      box-shadow: 0 18px 45px rgba(37,211,102,0.5);
    }
    .floating-whatsapp svg { width: 24px; height: 24px; flex-shrink: 0; }
    
    @media (max-width: 640px) {
      .floating-whatsapp { left: 14px; right: 14px; bottom: 16px; justify-content: center; }
    }
  </style>
</head>
<body>

  <div class="video-bg-container">
    <video autoplay loop muted playsinline poster="flight background.jpg">
      <source src="index background.mp4" type="video/mp4">
    </video>
    <div class="video-overlay"></div>
  </div>

  <header class="hero-simple shadow-lg">
    <div class="absolute top-0 right-4 w-20 h-24 md:w-24 md:h-30 bg-white rounded-b-xl p-2 flex items-center justify-center z-[110] shadow-xl">
      <img src="logo.png" alt="الريهام تورز" class="w-full h-full object-contain">
    </div>
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
